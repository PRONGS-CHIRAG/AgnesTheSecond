# Copy to `.env` and fill in secrets. All variables use the AGNES_ prefix.

AGNES_OPENAI_API_KEY=
AGNES_OPENAI_MODEL=gpt-4o-mini
# Tavily Search API key powers the Phase 5 search_web function-calling tool.
# Create one at https://app.tavily.com/
AGNES_TAVILY_API_KEY=
AGNES_DB_PATH=data/raw/db.sqlite
AGNES_LOG_LEVEL=INFO
# When true, loaders raise if Supplier_Rating / Price_Benchmark /
# Procurement_History tables are missing. Default (false) = degrade gracefully.
AGNES_PROCUREMENT_REQUIRED=false
# Cognee Cloud (cogwit-sdk). Create a key at https://platform.cognee.ai/
AGNES_COGWIT_API_KEY=
AGNES_COGWIT_DATASET=agnes
# Optional: override the Cognee Cloud base URL (default https://api.cognee.ai)
# AGNES_COGWIT_BASE_URL=

# Phase 4: substitute candidate generation
AGNES_PHASE4_TOP_K=10
AGNES_PHASE4_MIN_SCORE=0.55
AGNES_PHASE4_WEIGHTS={"family":0.30,"role":0.15,"embed":0.35,"lexical":0.10,"supplier_overlap":0.10}
AGNES_PHASE4_EMBEDDING_MODEL=text-embedding-3-small
AGNES_PHASE4_CROSS_FAMILY_DEFAULT=false

# Phase 5: external evidence enrichment (OpenAI + search_web function-calling tool)
AGNES_PHASE5_TOP_SOURCES=5
AGNES_PHASE5_PER_SOURCE=3
AGNES_PHASE5_MAX_TOTAL=25
AGNES_PHASE5_GROUNDED_MODEL=gpt-4o-mini

# Phase 6: context and compliance reasoning
AGNES_PHASE6_CLAIM_WEIGHTS={"functional_equivalence":0.35,"regulatory":0.25,"certification":0.15,"quality_sensory":0.10,"price_availability":0.10,"typical_suppliers":0.05}
AGNES_PHASE6_ACCEPT_THRESHOLD=0.75
AGNES_PHASE6_REJECT_THRESHOLD=0.35
AGNES_PHASE6_MIN_GROUNDED_CLAIMS=2
AGNES_PHASE6_MAX_LLM_CALLS=25
AGNES_PHASE6_LLM_MODEL=gpt-4o-mini

# Phase 7: recommendation engine
AGNES_PHASE7_SOURCING_WEIGHTS={"diversification":0.40,"company_overlap":0.35,"concentration_relief":0.25}
AGNES_PHASE7_FINAL_WEIGHTS={"acceptability":0.55,"substitute":0.25,"sourcing":0.20}
AGNES_PHASE7_SAFE_THRESHOLD=0.70
AGNES_PHASE7_REJECT_THRESHOLD=0.30
AGNES_PHASE7_TOP_N_POLISH=5
AGNES_PHASE7_MAX_LLM_CALLS=10
AGNES_PHASE7_LLM_MODEL=gpt-4o-mini

# Phase 8: demo UI (FastAPI + Next.js)
# Allowed browser origins for the FastAPI server.
AGNES_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Override when mounting outputs somewhere else (e.g. docker volume).
AGNES_REPORTS_DIR=outputs/reports
AGNES_REPO_ROOT=.
# Next.js reads this at build/run time (see frontend/.env.example).
NEXT_PUBLIC_API_URL=http://localhost:8000
